        "language": "python",
        "pythonCode": "import re\n\n# Récupération de l'URL depuis l'input\n# input_data est automatiquement fourni par n8n comme une liste de dictionnaires\n# Exemple: [{'url': 'https://www.amazon.com/dp/B0FLJMX2N6'}]\n\noutput = []\n\nfor item in items:  # items est la variable par défaut qui contient tous les inputs\n    url = item.get('json', {}).get('chatInput')  # on prend la clé 'url' du json\n    asin = None\n    if url:\n        match = re.search(r\"/dp/([A-Z0-9]{10})\", url)\n        if match:\n            asin = match.group(1)\n    output.append({\n        'json': {\n            'url': url,\n            'asin': asin\n        }\n    })\n\nreturn output\n"
      },
