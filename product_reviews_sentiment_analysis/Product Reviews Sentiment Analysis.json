    {
      "parameters": {
        "language": "python",
        "pythonCode": "# Constante pour la taille maximale d'un chunk\nMAX_CHARS = 480\n\ndef split_text_into_chunks(text, max_chars=MAX_CHARS):\n    \"\"\"\n    Divise un texte long en plusieurs morceaux sans couper les mots.\n    Chaque morceau ne dépasse pas max_chars caractères.\n    \"\"\"\n    words = text.split()\n    chunks = []\n    current_chunk = \"\"\n\n    for word in words:\n        # +1 pour l'espace entre les mots\n        if len(current_chunk) + len(word) + 1 <= max_chars:\n            current_chunk += (\" \" if current_chunk else \"\") + word\n        else:\n            chunks.append(current_chunk)\n            current_chunk = word\n\n    if current_chunk:\n        chunks.append(current_chunk)\n\n    return chunks\n\n\n#  Ici on suppose qu'il y a un seul item dans `items`\ntext = items[0].get(\"json\", {}).get(\"text\", \"\")\n\nif not text:\n    return []  # Rien à faire s'il n'y a pas de texte\n\nchunks = split_text_into_chunks(text)\n\n#  Construire la sortie pour n8n\noutput = [{\"json\": {\"chunk\": chunk, \"original_text\": text}} for chunk in chunks]\n\nreturn output\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
